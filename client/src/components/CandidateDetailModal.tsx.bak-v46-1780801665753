import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { trpc } from "@/lib/trpc";
import { AlertTriangle, CalendarDays, Car, ClipboardList, Database, MapPin, Phone, User, X } from "lucide-react";

type Props = { open: boolean; onOpenChange: (open: boolean) => void; candidateId: number };

const STATUS_STYLE: Record<string, string> = {
  대기: "bg-amber-50 text-amber-700 border border-amber-200",
  부과예정: "bg-sky-50 text-sky-700 border border-sky-200",
  부과반영완료: "bg-emerald-50 text-emerald-700 border border-emerald-200",
  확인필요: "bg-red-50 text-red-700 border border-red-200",
  보류: "bg-slate-100 text-slate-600 border border-slate-200",
  제외: "bg-gray-50 text-gray-500 border border-gray-200",
};

function value(v: any) { return v === null || v === undefined || v === "" ? "-" : String(v); }
function Row({ label, value: v }: { label: string; value: any }) {
  return <div className="space-y-1"><div className="text-[11px] font-medium text-slate-400">{label}</div><div className="break-words text-sm font-medium text-slate-800">{value(v)}</div></div>;
}
function Section({ icon, title, children }: { icon: React.ReactNode; title: string; children: React.ReactNode }) {
  return <section className="rounded-xl border border-slate-100 bg-slate-50/50 p-4"><h3 className="mb-3 flex items-center gap-2 text-sm font-semibold text-slate-900">{icon}{title}</h3><div className="grid gap-3 sm:grid-cols-2">{children}</div></section>;
}

function getWarnings(c: any): string[] {
  const warnings: string[] = [];
  if (!c?.billingStartMonth) warnings.push("부과시작일 없음");
  if (c?.status === "확인필요") warnings.push("확인 필요 상태");
  if (String(c?.memo || "").includes("중복")) warnings.push("중복 의심");
  if (String(c?.memo || "").includes("누락")) warnings.push("자료 누락");
  return [...new Set(warnings)];
}

export function CandidateDetailModal({ open, onOpenChange, candidateId }: Props) {
  const { data: candidate, isLoading } = trpc.billing.getCandidate.useQuery({ id: candidateId }, { enabled: open && candidateId > 0 });

  if (!open) return null;
  const c: any = candidate || {};
  const warnings = getWarnings(c);

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/45 p-4" onClick={() => onOpenChange(false)}>
      <div className="max-h-[88vh] w-full max-w-3xl overflow-y-auto rounded-2xl bg-white shadow-2xl" onClick={(e) => e.stopPropagation()}>
        <div className="sticky top-0 z-10 flex items-start justify-between gap-4 border-b border-slate-100 bg-white/95 px-6 py-5 backdrop-blur">
          <div>
            <h2 className="flex items-center gap-2 text-lg font-bold text-slate-950">부과 대상자 상세 정보 {warnings.length > 0 && <AlertTriangle className="h-4 w-4 text-amber-500" />}</h2>
            {!isLoading && <div className="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-500"><span className="font-semibold text-slate-900">{value(c.name)}</span><span>·</span><span>{value(c.vehicleNo)}</span><Badge className={STATUS_STYLE[c.status] || STATUS_STYLE.대기}>{value(c.status)}</Badge></div>}
          </div>
          <Button variant="ghost" size="sm" className="h-8 w-8 p-0" onClick={() => onOpenChange(false)}><X className="h-4 w-4" /></Button>
        </div>

        {isLoading ? (
          <div className="p-6 text-sm text-slate-500">상세 정보를 불러오는 중입니다...</div>
        ) : (
          <div className="space-y-4 p-6">
            {warnings.length > 0 && <div className="flex flex-wrap gap-2 rounded-xl border border-amber-200 bg-amber-50 p-3">{warnings.map((w) => <Badge key={w} className="border border-amber-200 bg-white text-amber-700">{w}</Badge>)}</div>}

            <Section title="기본 정보" icon={<User className="h-4 w-4 text-slate-400" />}>
              <Row label="성명" value={c.name} /><Row label="회원 구분" value={c.memberType} />
              <Row label="지역" value={c.region} /><Row label="관리 번호" value={c.managementNo} />
              <Row label="차량번호" value={c.vehicleNo} /><Row label="주민등록번호" value={c.rrn} />
            </Section>

            <Section title="연락처 / 주소" icon={<Phone className="h-4 w-4 text-slate-400" />}>
              <Row label="핸드폰" value={c.mobile} /><Row label="전화" value={c.phone} />
              <div className="sm:col-span-2"><Row label="주소" value={c.address} /></div>
            </Section>

            <Section title="인가·자격 정보" icon={<CalendarDays className="h-4 w-4 text-slate-400" />}>
              <Row label="가입일자" value={c.joinDate} /><Row label="부과시작일" value={c.billingStartMonth} />
              <Row label="자격증명발급일자" value={c.certificateDate} /><Row label="자격증명번호" value={c.certificateNo} />
              <Row label="면허번호" value={c.licenseNo} /><Row label="계산 기준" value={c.billingType} />
            </Section>

            <Section title="차량·사업 정보" icon={<Car className="h-4 w-4 text-slate-400" />}>
              <Row label="차량 유형" value={c.vehicleType} /><Row label="유종" value={c.fuelType} />
              <Row label="사업자번호" value={c.businessNo} /><Row label="회사명" value={c.company} />
            </Section>

            <Section title="부과 정보" icon={<ClipboardList className="h-4 w-4 text-slate-400" />}>
              <Row label="부과항목" value={c.billingType} /><Row label="상태" value={c.status} />
              <div className="sm:col-span-2"><Row label="메모" value={c.memo} /></div>
            </Section>

            <Section title="동기화 정보" icon={<Database className="h-4 w-4 text-slate-400" />}>
              <Row label="원본 시스템 ID" value={c.sourceSystemId} /><Row label="등록일시" value={c.createdAt} />
              <Row label="수정일시" value={c.updatedAt} /><Row label="내부 ID" value={c.id} />
            </Section>

            <div className="flex justify-end gap-2 pt-2"><Button variant="outline" onClick={() => onOpenChange(false)}>닫기</Button></div>
          </div>
        )}
      </div>
    </div>
  );
}


/* v39 helper: 부과항목별 금액 계산 */
function getBillingAmountByTypeV40(itemOrType: any): number {
  const raw = typeof itemOrType === "string"
    ? itemOrType
    : String(itemOrType?.billingType || itemOrType?.billing_type || itemOrType?.feeType || itemOrType?.chargeType || itemOrType?.billing_type_name || itemOrType?.billingItem || itemOrType?.billing_item || itemOrType?.부과항목 || "");
  if (raw.includes("관리")) return 5000;
  if (raw.includes("협회")) return 10000;

  // 회원구분만 있는 경우 보조 판단: 택배회원은 관리비 가능성이 높지만,
  // 실제 billingType이 없으면 안전하게 0원 처리해서 잘못 과대계산하지 않음.
  return 0;
}

function getBillingTotalAmountV40(items: any[]): number {
  return (items || []).reduce((sum, item) => sum + getBillingAmountByTypeV40(item), 0);
}

function getBillingPreviewUnitAmountLabelV43(getBillingPreviewItemsV43()): string {
  const amounts = Array.from(new Set((items || []).map(getBillingAmountByTypeV40).filter(Boolean)));
  if (amounts.length === 1) return amounts[0].toLocaleString("ko-KR");
  if (amounts.length > 1) return "항목별";
  return "0";
}
/* v39 helper end */


